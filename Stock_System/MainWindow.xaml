<Window Closing="Window_Closing" x:Class="EstoqueRolos.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Controle de Estoque - Bobinas"
        Height="700" Width="1500"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource BrushLightGray}"
        Icon="/Logo.png">

    <Window.Resources>
        <!-- Estilo para Botão de Menu Lateral -->
        <Style x:Key="SidebarMenuButton" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="0,15"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" Padding="{TemplateBinding Padding}">
                            <Grid HorizontalAlignment="Left" Margin="17,0,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="25"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock x:Name="txtIcon" Grid.Column="0" Text="{Binding Tag, RelativeSource={RelativeSource TemplatedParent}}" TextAlignment="Center" FontSize="16" VerticalAlignment="Center"/>
                                <TextBlock x:Name="txtLabel" Grid.Column="1" Text="{TemplateBinding Content}" Margin="15,0,0,0" VerticalAlignment="Center">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding Width.Value, ElementName=colSidebar}" Value="60">
                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </Grid>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#0D3D3F"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Estilo para Botão de Ação -->
        <Style x:Key="ActionButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#17A2A2"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="15,8"/>
            <Setter Property="Margin" Value="5,0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" Padding="{TemplateBinding Padding}" CornerRadius="4">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#20B2AA"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Estilo para Botão Verde (Novo) -->
        <Style x:Key="GreenButtonStyle" TargetType="Button" BasedOn="{StaticResource ActionButtonStyle}">
            <Setter Property="Background" Value="#6BA539"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#7CB545"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Estilo para DataGrid -->
        <Style TargetType="{x:Type DataGrid}">
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="{StaticResource BrushMediumGray}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="RowHeight" Value="40"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="GridLinesVisibility" Value="Horizontal"/>
            <Setter Property="HorizontalGridLinesBrush" Value="{StaticResource BrushMediumGray}"/>
            <Setter Property="RowBackground" Value="White"/>
            <Setter Property="AlternatingRowBackground" Value="#FAFAFA"/>
        </Style>

        <Style TargetType="{x:Type DataGridColumnHeader}">
            <Setter Property="Background" Value="#F0F0F0"/>
            <Setter Property="Foreground" Value="{StaticResource BrushTextDark}"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Padding" Value="12,10"/>
            <Setter Property="BorderThickness" Value="0,0,1,1"/>
            <Setter Property="BorderBrush" Value="{StaticResource BrushMediumGray}"/>
        </Style>

        <Style TargetType="{x:Type DataGridCell}">
            <Setter Property="Padding" Value="10,0"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="BorderThickness" Value="0"/>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition x:Name="colSidebar" Width="60"/>
            <ColumnDefinition Width="219*"/>
            <ColumnDefinition Width="41*"/>
        </Grid.ColumnDefinitions>

        <!-- Overlay de Boas-vindas -->
        <Border x:Name="welcomeOverlay" Grid.ColumnSpan="3" Panel.ZIndex="1000" Background="{StaticResource BrushTeal}">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                <TextBlock x:Name="txtWelcome" Text="Bem-vindo(a)" Foreground="White" FontSize="48" FontWeight="Bold" HorizontalAlignment="Center" Opacity="0">
                    <TextBlock.RenderTransform>
                        <TranslateTransform Y="20"/>
                    </TextBlock.RenderTransform>
                </TextBlock>
                <TextBlock x:Name="txtSubtitle" Text="Controle de Estoque de Bobinas" Foreground="White" FontSize="24" Margin="0,20,0,0" HorizontalAlignment="Center" Opacity="0"/>
            </StackPanel>
            <Border.Triggers>
                <EventTrigger RoutedEvent="Loaded">
                    <BeginStoryboard>
                        <Storyboard>
                            <!-- Animação do "Bem-vindo(a)" -->
                            <DoubleAnimation Storyboard.TargetName="txtWelcome" Storyboard.TargetProperty="Opacity" To="1" Duration="0:0:1" BeginTime="0:0:0.5"/>
                            <DoubleAnimation Storyboard.TargetName="txtWelcome" Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.Y)" To="0" Duration="0:0:1" BeginTime="0:0:0.5">
                                <DoubleAnimation.EasingFunction>
                                    <CubicEase EasingMode="EaseOut"/>
                                </DoubleAnimation.EasingFunction>
                            </DoubleAnimation>

                            <!-- Animação do Subtítulo -->
                            <DoubleAnimation Storyboard.TargetName="txtSubtitle" Storyboard.TargetProperty="Opacity" To="1" Duration="0:0:1" BeginTime="0:0:1.5"/>

                            <!-- Fade out do overlay e remoção -->
                            <DoubleAnimation Storyboard.TargetName="welcomeOverlay" Storyboard.TargetProperty="Opacity" To="0" Duration="0:0:0.8" BeginTime="0:0:3.5"/>
                            <ObjectAnimationUsingKeyFrames Storyboard.TargetName="welcomeOverlay" Storyboard.TargetProperty="Visibility" BeginTime="0:0:4.3">
                                <DiscreteObjectKeyFrame KeyTime="0" Value="{x:Static Visibility.Collapsed}"/>
                            </ObjectAnimationUsingKeyFrames>
                        </Storyboard>
                    </BeginStoryboard>
                </EventTrigger>
            </Border.Triggers>
        </Border>

        <!-- SIDEBAR ESQUERDA -->
        <Border Grid.Column="0" Background="{StaticResource BrushSidebarDark}" x:Name="sidebarBorder">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Logo/Menu Toggle -->
                <Button x:Name="btnMenuToggle" Click="MenuToggle_Click" Style="{StaticResource SidebarMenuButton}" Tag="☰" Content="MENU" FontWeight="Bold"/>

                <StackPanel Grid.Row="1" VerticalAlignment="Top" Margin="0,10,0,0">
                    <Button Style="{StaticResource SidebarMenuButton}" Tag="⊕" Content="NOVA BOBINA" Click="Novo_Click"/>
                    <Button Style="{StaticResource SidebarMenuButton}" Tag="✎" Content="EDITAR ITEM" Click="Editar_Click"/>
                    <Button Style="{StaticResource SidebarMenuButton}" Tag="✕" Content="EXCLUIR ITEM" Click="Excluir_Click"/>
                    <Button Style="{StaticResource SidebarMenuButton}" Tag="📊" Content="CALCULADORA" Click="Calcular_Click"/>
                    <Button Style="{StaticResource SidebarMenuButton}" Tag="📁" Content="EXPORTAR EXCEL" Click="Exportar_Click"/>
                    <Button Style="{StaticResource SidebarMenuButton}" Tag="🔄" Content="ATUALIZAR" Click="Atualizar_Click"/>
                    <Button Style="{StaticResource SidebarMenuButton}" Tag="⬆" Content="CARREGAR BANCO" Click="MenuCarregarBanco_Click"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- CONTEÚDO PRINCIPAL -->
        <Grid Grid.Column="1" Grid.ColumnSpan="2">
            <Grid.RowDefinitions>
                <RowDefinition Height="60"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- HEADER BRANCO -->
            <Border Grid.Row="0" Background="White" BorderBrush="{StaticResource BrushMediumGray}" BorderThickness="0,0,0,1">
                <DockPanel Margin="25,0" VerticalAlignment="Center">
                    <TextBlock Text="Controle de Estoque de Bobinas" FontSize="18" FontWeight="Bold" Foreground="{StaticResource BrushTeal}" VerticalAlignment="Center"/>

                    <StackPanel Orientation="Horizontal" DockPanel.Dock="Right" VerticalAlignment="Center">
                        <Button Content="👤 Usuário - Beta Tester" Width="153" Height="35" Background="Transparent" Foreground="{StaticResource BrushTextDark}" BorderThickness="0" Cursor="Hand"/>
                    </StackPanel>
                </DockPanel>
            </Border>

            <!-- ÁREA DE DADOS -->
            <Grid Grid.Row="1" Margin="25">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- BARRA DE BUSCA E AÇÕES -->
                <Border Grid.Row="0" Background="White" Padding="20" CornerRadius="8" BorderBrush="{StaticResource BrushMediumGray}" BorderThickness="1" Margin="0,0,0,20">
                    <DockPanel>
                        <TextBlock Text="Pesquisar:" VerticalAlignment="Center" Margin="0,0,15,0" FontWeight="SemiBold" Foreground="{StaticResource BrushTextDark}"/>
                        <TextBox x:Name="txtBusca" Width="350" Height="35" Padding="10,5" Foreground="{StaticResource BrushTextDark}" Background="White" BorderBrush="{StaticResource BrushMediumGray}" BorderThickness="1" VerticalContentAlignment="Center"/>
                        <Button Content="Buscar" Click="Buscar_Click" Style="{StaticResource ActionButtonStyle}" Width="100" Height="35" Margin="10,0,0,0"/>
                        <Button Content="Limpar" Click="LimparBusca_Click" Style="{StaticResource ActionButtonStyle}" Width="100" Height="35" Background="{StaticResource BrushMediumGray}" Foreground="{StaticResource BrushTextDark}"/>

                        <Button Content="+ Nova Bobina" Click="Novo_Click" Style="{StaticResource GreenButtonStyle}" DockPanel.Dock="Right" HorizontalAlignment="Right" Width="140" Height="35"/>
                    </DockPanel>
                </Border>

                <!-- TABELA DE DADOS -->
                <Border Grid.Row="1" Background="White" CornerRadius="8" BorderBrush="{StaticResource BrushMediumGray}" BorderThickness="1">
                    <DataGrid x:Name="dgRolos"
                              AutoGenerateColumns="False"
                              IsReadOnly="True"
                              CanUserAddRows="False"
                              SelectionMode="Single"
                              ColumnWidth="*"
                              BorderThickness="0">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Código" Binding="{Binding Code}" Width="120"/>
                            <DataGridTextColumn Header="Descrição do Produto" Binding="{Binding Descricao}" Width="2*"/>
                            <DataGridTextColumn Header="MM" Binding="{Binding Milimetragem}" Width="80"/>
                            <DataGridTextColumn Header="Std Pack" Binding="{Binding MOQ}" Width="100"/>
                            <DataGridTextColumn Header="Estoque (m)" Binding="{Binding Estoque}" Width="120"/>
                            <DataGridTextColumn Header="Metragem WIP" Binding="{Binding MetragemWIP}" Width="130"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </Border>
            </Grid>
        </Grid>
    </Grid>
</Window>
