<Window x:Class="EstoqueRolos.Views.CalculadoraMetragem"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Calcular Metragem Disponível"
        Height="580" Width="800"
        WindowStartupLocation="CenterOwner"
        Background="{StaticResource BrushLightGray}"
        ResizeMode="NoResize"
        Icon="/Views/Logo.png">

    <Window.Resources>
        <Style TargetType="Label">
            <Setter Property="Foreground" Value="{StaticResource BrushTextDark}"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Margin" Value="0,0,0,2"/>
        </Style>

        <Style TargetType="TextBox">
            <Setter Property="Padding" Value="8,5"/>
            <Setter Property="Margin" Value="0,0,0,15"/>
            <Setter Property="BorderBrush" Value="{StaticResource BrushMediumGray}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Height" Value="32"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>

        <Style x:Key="CalcButtonStyle" TargetType="Button">
            <Setter Property="Padding" Value="20,8"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="60"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="70"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Background="{StaticResource BrushTeal}" Padding="20,0">
            <DockPanel VerticalAlignment="Center">
                <TextBlock Text="📱 CALCULAR METRAGEM" 
                           Foreground="White" 
                           FontSize="16" 
                           FontWeight="Bold" 
                           VerticalAlignment="Center"/>
                <ComboBox Name="myComboBox" 
                          DockPanel.Dock="Right" 
                          HorizontalAlignment="Right" 
                          Width="220" 
                          Height="32" 
                          VerticalContentAlignment="Center"
                          SelectionChanged="myComboBox_SelectionChanged">
                    <ComboBoxItem Content="Selecione um Padrão..." IsSelected="True"/>
                    <ComboBoxItem Content="Bobina de 200mm" />
                    <ComboBoxItem Content="Bobina de 250mm" />
                    <ComboBoxItem Content="Bobina de 355mm" />
                </ComboBox>
            </DockPanel>
        </Border>

        <!-- Main Content -->
        <Grid Grid.Row="1" Margin="20">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="300"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Inputs -->
            <Border Grid.Column="0" Background="White" Padding="20" BorderBrush="{StaticResource BrushMediumGray}" BorderThickness="1">
                <StackPanel>
                    <TextBlock Text="Parâmetros de Entrada" FontWeight="Bold" Margin="0,0,0,15" Foreground="{StaticResource BrushTeal}"/>
                    
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" Margin="0,0,5,0">
                            <Label Content="Raio Externo (R)"/>
                            <TextBox x:Name="txtR" PreviewTextInput="NumberValidationTextBox"/>
                        </StackPanel>
                        <StackPanel Grid.Column="1" Margin="5,0,0,0">
                            <Label Content="Raio Interno (r)"/>
                            <TextBox x:Name="txtr" PreviewTextInput="NumberValidationTextBox"/>
                        </StackPanel>
                    </Grid>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" Margin="0,0,5,0">
                            <Label Content="Espessura (E0)"/>
                            <TextBox x:Name="txtE0" PreviewTextInput="NumberValidationTextBox"/>
                        </StackPanel>
                        <StackPanel Grid.Column="1" Margin="5,0,0,0">
                            <Label Content="Profundidade"/>
                            <TextBox x:Name="txtE" PreviewTextInput="NumberValidationTextBox"/>
                        </StackPanel>
                    </Grid>

                    <Label Content="Standard Pack"/>
                    <TextBox x:Name="txtMmax" PreviewTextInput="NumberValidationTextBox"/>

                    <Button Content="Calcular Metragem" 
                            Click="Calcular_Click" 
                            Style="{StaticResource CalcButtonStyle}" 
                            Background="{StaticResource BrushTeal}" 
                            Foreground="White"
                            Height="40"
                            Margin="0,10,0,0"/>
                </StackPanel>
            </Border>

            <!-- Visual/Result -->
            <Border Grid.Column="1" Background="White" Margin="15,0,0,0" Padding="20" BorderBrush="{StaticResource BrushMediumGray}" BorderThickness="1">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Text="Representação Técnica" FontWeight="Bold" Foreground="{StaticResource BrushTeal}"/>
                    
                    <Image Grid.Row="1" Source="/Imagens/Bobina.png" Margin="20" Stretch="Uniform"/>

                    <Border Grid.Row="2" Background="#F8FAFC" Padding="15" BorderBrush="{StaticResource BrushMediumGray}" BorderThickness="0,1,0,0">
                        <DockPanel>
                            <Label Content="Resultado (m):" VerticalAlignment="Center" Margin="0,0,10,0"/>
                            <TextBox x:Name="txtResultado" 
                                     IsReadOnly="True" 
                                     Height="35" 
                                     FontSize="16" 
                                     FontWeight="Bold" 
                                     TextAlignment="Center"
                                     Background="#F0F0F0"
                                     Margin="0,0,10,0"/>
                            <Button Content="Copiar" 
                                    Click="Copiar_Click" 
                                    Width="80" 
                                    Style="{StaticResource CalcButtonStyle}" 
                                    Background="{StaticResource BrushMediumGray}" 
                                    Foreground="{StaticResource BrushTextDark}"/>
                        </DockPanel>
                    </Border>
                </Grid>
            </Border>
        </Grid>

        <!-- Footer -->
        <Border Grid.Row="2" Background="#F0F0F0" Padding="20,0">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                <Button Content="Fechar" 
                        Click="Cancelar_Click" 
                        Style="{StaticResource CalcButtonStyle}" 
                        Background="{StaticResource BrushMediumGray}" 
                        Foreground="{StaticResource BrushTextDark}"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>
