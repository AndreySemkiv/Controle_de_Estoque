<Window x:Class="EstoqueRolos.Views.RoloDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Dados da Bobina"
        Height="550" Width="450"
        WindowStartupLocation="CenterOwner"
        Background="{StaticResource BrushLightGray}"
        ResizeMode="NoResize"
        Icon="/Views/Logo.png">

    <Window.Resources>
        <Style TargetType="Label">
            <Setter Property="Foreground" Value="{StaticResource BrushTextDark}"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Margin" Value="0,0,0,2"/>
        </Style>

        <Style TargetType="TextBox">
            <Setter Property="Padding" Value="8,5"/>
            <Setter Property="Margin" Value="0,0,0,15"/>
            <Setter Property="BorderBrush" Value="{StaticResource BrushMediumGray}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Height" Value="32"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>

        <Style x:Key="DialogButtonStyle" TargetType="Button">
            <Setter Property="Padding" Value="20,8"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="60"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="70"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Background="{StaticResource BrushTeal}" Padding="20,0">
            <TextBlock Text="📄 DADOS DA BOBINA" 
                       Foreground="White" 
                       FontSize="16" 
                       FontWeight="Bold" 
                       VerticalAlignment="Center"/>
        </Border>

        <!-- Form -->
        <Border Grid.Row="1" Background="White" Margin="20" Padding="20" BorderBrush="{StaticResource BrushMediumGray}" BorderThickness="1">
            <StackPanel>
                <Label Content="Código"/>
                <TextBox x:Name="txtCode"/>

                <Label Content="Descrição"/>
                <TextBox x:Name="txtDescricao"/>

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0" Margin="0,0,10,0">
                        <Label Content="Milimetragem"/>
                        <TextBox x:Name="txtMM"/>
                    </StackPanel>
                    <StackPanel Grid.Column="1" Margin="10,0,0,0">
                        <Label Content="Standard Pack"/>
                        <TextBox x:Name="txtMOQ"/>
                    </StackPanel>
                </Grid>

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0" Margin="0,0,10,0">
                        <Label Content="Estoque (m)"/>
                        <TextBox x:Name="txtEstoque"/>
                    </StackPanel>
                    <StackPanel Grid.Column="1" Margin="10,0,0,0">
                        <Label Content="Metragem WIP"/>
                        <TextBox x:Name="txtWIP"/>
                    </StackPanel>
                </Grid>
            </StackPanel>
        </Border>

        <!-- Footer -->
        <Border Grid.Row="2" Background="#F0F0F0" Padding="20,0">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                <Button Content="Cancelar" 
                        Click="Cancelar_Click" 
                        Style="{StaticResource DialogButtonStyle}" 
                        Background="{StaticResource BrushMediumGray}" 
                        Foreground="{StaticResource BrushTextDark}"
                        Margin="0,0,10,0"/>
                <Button Content="Salvar Registro" 
                        Click="Salvar_Click" 
                        Style="{StaticResource DialogButtonStyle}" 
                        Background="{StaticResource BrushTeal}" 
                        Foreground="White"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>
